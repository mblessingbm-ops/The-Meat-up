# ZIMRA — Environment Variables
# Copy to .env.local and populate before running

# ── Environment ───────────────────────────────────────────────────────────────
ZIMRA_API_BASE_URL=https://fdmsapitest.zimra.co.zw
ZIMRA_DEVICE_MODEL_NAME=KingsportPlatform
ZIMRA_DEVICE_MODEL_VERSION=1.0.0

# ── Cron security ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ── Phase 1 — Kingsport ───────────────────────────────────────────────────────
# Obtain deviceID and activationKey from ZIMRA taxpayer portal
ZIMRA_DEVICE_ID_KINGSPORT=
ZIMRA_ACTIVATION_KEY_KINGSPORT=

# Certificate PEM — obtained by calling POST /api/zimra/device/register
# Store multiline PEM with newlines replaced by \n
ZIMRA_CERT_PEM_KINGSPORT=

# Private key PEM — generated locally, never leaves your server
ZIMRA_PRIVATE_KEY_PEM_KINGSPORT=

# ── Phase 2 — leave commented until ready ─────────────────────────────────────
# ZIMRA_DEVICE_ID_BRALYN=
# ZIMRA_ACTIVATION_KEY_BRALYN=
# ZIMRA_CERT_PEM_BRALYN=
# ZIMRA_PRIVATE_KEY_PEM_BRALYN=

# ZIMRA_DEVICE_ID_SGA=
# ZIMRA_ACTIVATION_KEY_SGA=
# ZIMRA_CERT_PEM_SGA=
# ZIMRA_PRIVATE_KEY_PEM_SGA=
